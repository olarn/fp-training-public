    {
      "id": "code-text",
      "type": "text",
      "x": 60,
      "y": 85,
      "width": 600,
      "height": 490,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 190003,
      "version": 1,
      "versionNonce": 190003,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781324985821,
      "link": null,
      "locked": false,
      "text": "type Writer<A> = [A, string]\n\ntype Chain = <A, B, C>\n  (f: (a: A) => Writer<B>) =>\n    (g: (b: B) => Writer<C>) =>\n      (a: A) => Writer<C>\n\nconst chain: Chain =\n  (f) => (g) => (a) => {\n    const [b, log1] = f(a)\n    const [c, log2] = g(b)\n    return [c, log1 + log2]\n  }\n\nconst of = <A>(a: A): Writer<A> => [a, '']\n\nconst upcase = (str) =>\n  [str.toUpperCase(), 'upcase ']\n\nconst toWords = (str) =>\n  [str.split(' '), 'toWords ']\n\nconst countWords = (words) =>\n  [words.length, 'countWords']",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "type Writer<A> = [A, string]\n\ntype Chain = <A, B, C>\n  (f: (a: A) => Writer<B>) =>\n    (g: (b: B) => Writer<C>) =>\n      (a: A) => Writer<C>\n\nconst chain: Chain =\n  (f) => (g) => (a) => {\n    const [b, log1] = f(a)\n    const [c, log2] = g(b)\n    return [c, log1 + log2]\n  }\n\nconst of = <A>(a: A): Writer<A> => [a, '']\n\nconst upcase = (str) =>\n  [str.toUpperCase(), 'upcase ']\n\nconst toWords = (str) =>\n  [str.split(' '), 'toWords ']\n\nconst countWords = (words) =>\n  [words.length, 'countWords']",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "writer-note",
      "type": "text",
      "x": 720,
      "y": 80,
      "width": 470,
      "height": 100,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 190004,
      "version": 1,
      "versionNonce": 190004,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781324985821,
      "link": null,
      "locked": false,
      "text": "Writer<A> = [A, string]\n   A       =  the value\n   string  =  accumulated log\n\nA Kleisli arrow is a function  A => Writer<B>.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Writer<A> = [A, string]\n   A       =  the value\n   string  =  accumulated log\n\nA Kleisli arrow is a function  A => Writer<B>.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
