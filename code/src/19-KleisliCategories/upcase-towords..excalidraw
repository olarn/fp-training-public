      "lineHeight": 1.25
    },
    {
      "id": "chain-note",
      "type": "text",
      "x": 720,
      "y": 320,
      "width": 470,
      "height": 90,
      "angle": 0,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 190006,
      "version": 1,
      "versionNonce": 190006,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781324985821,
      "link": null,
      "locked": false,
      "text": "chain  =  Kleisli composition  (>=>)\n   runs f, then g, and\n   concatenates both logs: log1 + log2.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "chain  =  Kleisli composition  (>=>)\n   runs f, then g, and\n   concatenates both logs: log1 + log2.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "laws-note",
      "type": "text",
      "x": 720,
      "y": 440,
      "width": 470,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 190007,
      "version": 1,
      "versionNonce": 190007,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781324985821,
      "link": null,
      "locked": false,
      "text": "Kleisli Category Laws\n  left identity  :  chain(of)(f) = f\n  right identity :  chain(f)(of) = f\n  associativity  :  chain(chain(f)(g))(h)\n                  =  chain(f)(chain(g)(h))",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kleisli Category Laws\n  left identity  :  chain(of)(f) = f\n  right identity :  chain(f)(of) = f\n  associativity  :  chain(chain(f)(g))(h)\n                  =  chain(f)(chain(g)(h))",
      "autoResize": true,
      "lineHeight": 1.25
    },
